# Restrict sign-in to your Workspace domain (default: carehelps.ca)
CARE_ALLOWED_EMAIL_DOMAIN=carehelps.ca

# Local storage (default: Videos\CARE Meet Recordings — changeable in the app)
CARE_RECORDINGS_DIR=
# Optional mapped Synology folder, e.g. Z:\CARE\TempRecordings
CARE_SYNOLOGY_PATH=

# FFmpeg / Whisper (auto-detected from installer bundle; override only if needed)
# CARE_FFMPEG_PATH=
# CARE_WHISPER_PATH=
# CARE_WHISPER_MODEL_PATH=
CARE_WHISPER_ENABLED=true

# Google Cloud project: care-meet-recorder
# See docs/GOOGLE_CLOUD_SETUP.md for full walkthrough
GOOGLE_CLIENT_ID=
# Google client secret is optional for desktop OAuth; keep it out of installers.
GOOGLE_CLIENT_SECRET=
# API key for the Google Drive folder picker (Credentials → Create credentials → API key).
# Enable the "Google Picker API" in APIs & Services. FIREBASE_API_KEY works as a fallback.
GOOGLE_API_KEY=
GOOGLE_REDIRECT_URI=http://127.0.0.1:42813/oauth2callback
GOOGLE_DRIVE_FOLDER_ID=

# Optional: read-only GitHub PAT for auto-updates when the release repo is private
# CARE_GITHUB_UPDATE_TOKEN=

# Firebase metadata only (optional — can reuse meetroom-df237)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
