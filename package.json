{
  "name": "care-meet-companion",
  "version": "0.1.11",
  "description": "CARE Meet Companion — host-side Google Meet recording app",
  "main": "out/main/index.js",
  "author": "CARE",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/anyusernamechs/care-meet-companion.git"
  },
  "scripts": {
    "dev": "npm run generate-icon && node scripts/copy-main-assets.mjs && electron-vite dev",
    "build": "electron-vite build && node scripts/copy-main-assets.mjs",
    "preview": "electron-vite preview",
    "prepare-tools": "powershell -ExecutionPolicy Bypass -File scripts/prepare-bundled-tools.ps1",
    "generate-icon": "node scripts/generate-icon.mjs",
    "package": "npm run generate-icon && npm run prepare-tools && npm run build && electron-builder --win nsis",
    "package:signed": "powershell -ExecutionPolicy Bypass -File scripts/package-signed.ps1",
    "package:publish": "npm run generate-icon && npm run prepare-tools && npm run build && electron-builder --win nsis --publish always",
    "package:dir": "npm run generate-icon && npm run prepare-tools && npm run build && electron-builder --win dir",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "electron-updater": "^6.6.2",
    "firebase": "^11.6.0",
    "googleapis": "^148.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "sharp": "^0.35.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  },
  "build": {
    "appId": "org.care.meet-companion",
    "productName": "CARE Meet Companion",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "publisherName": "CARE Helps Society",
      "signAndEditExecutable": true,
      "signDlls": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "differentialPackage": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CARE Meet Companion",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/branding",
        "to": "branding",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ]
  }
}
